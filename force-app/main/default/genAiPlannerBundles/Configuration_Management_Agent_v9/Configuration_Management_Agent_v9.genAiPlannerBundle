        </localActions>
        <localActions>
            <fullName>BulkUpdateBundleAttribute_179Ws000000ZtMd</fullName>
            <description>Set the SAME attribute value (e.g. Operating System, Base Core Count) on EVERY instance of a bundle product on a quote in one deterministic pass. Use when the user wants to change/swap an ATTRIBUTE on all instances of a bundle. Optionally limit the change to named groups/regions via groupNames (e.g. &apos;California, New York&apos;); leave groupNames blank to apply to the whole quote. Provide attributeName (exactly as shown on the bundle) and desiredValue. Picklist attributes are validated against allowed values up front and rejected if invalid (errorMessage lists the allowed values). All-or-nothing: if any instance is blocked, nothing is saved.</description>
            <developerName>BulkUpdateBundleAttribute_179Ws000000ZtMd</developerName>
            <invocationTarget>BulkUpdateBundleAttribute</invocationTarget>
            <invocationTargetType>apex</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
            <isIncludeInProgressIndicator>false</isIncludeInProgressIndicator>
            <localDeveloperName>BulkUpdateBundleAttribute</localDeveloperName>
            <masterLabel>Bulk Update Bundle Attribute</masterLabel>
        </localActions>
