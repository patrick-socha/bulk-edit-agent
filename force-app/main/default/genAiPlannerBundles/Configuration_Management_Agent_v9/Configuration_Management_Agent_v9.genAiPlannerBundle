        <localActions>
            <fullName>GetAttributePicklistValues_179Ws000000ZtMd</fullName>
            <description>For a picklist attribute, list its valid values and their picklist value IDs. Pass the attribute&apos;s CURRENT AttributePicklistValue ID (from the GetConfiguratorInstance JSON). Use the returned IDs to set a new picklist attribute value via UpdateConfiguratorNodes.</description>
            <developerName>GetAttributePicklistValues_179Ws000000ZtMd</developerName>
