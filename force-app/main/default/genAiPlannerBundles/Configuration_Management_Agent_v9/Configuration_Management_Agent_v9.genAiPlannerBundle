        </localActions>
        <localActions>
            <fullName>BulkSelectBundleComponent_179Ws000000ZtMd</fullName>
            <description>Apply the SAME component change to EVERY instance of a bundle product on a quote in one deterministic pass. Use when the user says &apos;all&apos; / &apos;every&apos;, or when there are multiple instances of the same bundle. Optionally limit the change to named groups/regions via groupNames (e.g. &apos;California, New York&apos;); leave groupNames blank to apply to the whole quote. SELECT needs productRelatedComponentId; DESELECT needs childProductId. All-or-nothing: if any instance is blocked by bundle rules, nothing is saved. Reports per-bundle results. Cannot create new products or delete arbitrary records.</description>
            <developerName>BulkSelectBundleComponent_179Ws000000ZtMd</developerName>
            <invocationTarget>BulkSelectBundleComponent</invocationTarget>
            <invocationTargetType>apex</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
            <isIncludeInProgressIndicator>false</isIncludeInProgressIndicator>
            <localDeveloperName>BulkSelectBundleComponent</localDeveloperName>
            <masterLabel>Bulk Select Bundle Component</masterLabel>
        </localActions>
