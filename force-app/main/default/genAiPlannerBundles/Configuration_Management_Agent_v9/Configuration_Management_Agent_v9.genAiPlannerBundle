        <localActions>
            <fullName>SelectBundleComponent_179Ws000000ZtMd</fullName>
            <description>Select (turn on) or deselect (turn off) a predefined bundle component option, honoring bundle rules. This cannot create a new product or delete an arbitrary record — it only toggles predefined options. If a bundle rule prevents the change, ruleBlocked is true and nothing is saved.</description>
            <developerName>SelectBundleComponent_179Ws000000ZtMd</developerName>
            <invocationTarget>SelectBundleComponent</invocationTarget>
            <invocationTargetType>apex</invocationTargetType>
