        </localActions>
        <localActions>
            <fullName>SaveConfiguratorInstance_179Ws000000ZtMd</fullName>
            <description>THE save action for committing configuration changes (attributes, quantities, components) to the quote itself. This is what you call when the user confirms they want to save their changes. Commits the current configuration session (sessionContextId) to the quote. ONLY call after explicit user confirmation. Do NOT call more than once per turn.</description>
            <developerName>SaveConfiguratorInstance_179Ws000000ZtMd</developerName>
            <invocationTarget>SaveConfiguratorInstance</invocationTarget>
            <invocationTargetType>apex</invocationTargetType>
